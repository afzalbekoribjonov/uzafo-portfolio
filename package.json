{
  "name": "uzafo-portfolio-site",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Multilingual portfolio frontend for UZAFO built with Next.js, Tailwind CSS, next-intl, Tiptap, and demo JSON data.",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true}); fs.rmSync('node_modules/.cache',{recursive:true,force:true});\"",
    "dev": "next dev --hostname localhost --port 3000",
    "dev:clean": "npm run clean:next && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "16.2.1",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
