# ─────────────────────────────────────────────────────────────────────────────
# UZAFO PORTFOLIO — Environment Variables
# Copy this file to .env.local and fill in your own values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# When NEXT_PUBLIC_API_BASE is set, src/lib/api-service.ts routes all data
# calls to your real backend instead of the local demo store.
# Leave empty to keep running in demo mode (no backend needed).
NEXT_PUBLIC_API_BASE=

# Example production value:
# NEXT_PUBLIC_API_BASE=https://api.yoursite.com

# Public site URL used for metadata, sitemap, robots, and canonical links.
# If you later move the frontend to a subdomain, update this value to match it.
NEXT_PUBLIC_SITE_URL=https://uzafo.site

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Admin authentication must always be validated by the backend.
# Never place admin emails or passwords in NEXT_PUBLIC_* variables.

# ── Optional features ─────────────────────────────────────────────────────────
# Enable when you wire up real Google OAuth on the backend.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
